{
  "$schema": "https://design-tokens.org/schema/",
  "$description": "Light-mode semantic color tokens for the shadcn Vega preset (neutral baseColor). Each token references a primitive in primitives.json via DTCG {} alias — Style Dictionary resolves at build time to literal hex values. Aliases match Vega's `shadcn init` output mapped to the closest Tailwind primitive.",
  "color": {
    "background-default": { "$value": "{primitives.color.white}", "$type": "color" },
    "foreground-default": { "$value": "{primitives.color.neutral.950}", "$type": "color" },
    "card-background": { "$value": "{primitives.color.white}", "$type": "color" },
    "card-foreground": { "$value": "{primitives.color.neutral.950}", "$type": "color" },
    "popover-background": { "$value": "{primitives.color.white}", "$type": "color" },
    "popover-foreground": { "$value": "{primitives.color.neutral.950}", "$type": "color" },
    "background-primary": { "$value": "{primitives.color.neutral.900}", "$type": "color" },
    "foreground-primary": { "$value": "{primitives.color.neutral.900}", "$type": "color" },
    "foreground-default-inverse": { "$value": "{primitives.color.neutral.50}", "$type": "color" },
    "background-default-inverse": { "$value": "{primitives.color.neutral.900}", "$type": "color" },
    "background-secondary": { "$value": "{primitives.color.neutral.100}", "$type": "color" },
    "background-muted": { "$value": "{primitives.color.neutral.100}", "$type": "color" },
    "foreground-muted": { "$value": "{primitives.color.neutral.500}", "$type": "color" },
    "foreground-icon": { "$value": "{primitives.color.neutral.500}", "$type": "color" },
    "background-accent": { "$value": "{primitives.color.neutral.100}", "$type": "color" },
    "background-destructive": { "$value": "{primitives.color.red.600}", "$type": "color" },
    "border-default": { "$value": "{primitives.color.neutral.200}", "$type": "color" },
    "input-border": { "$value": "{primitives.color.neutral.200}", "$type": "color" },
    "ring-default": { "$value": "{primitives.color.neutral.400}", "$type": "color" },
    "chart-1": { "$value": "{primitives.color.neutral.300}", "$type": "color" },
    "chart-2": { "$value": "{primitives.color.neutral.500}", "$type": "color" },
    "chart-3": { "$value": "{primitives.color.neutral.600}", "$type": "color" },
    "chart-4": { "$value": "{primitives.color.neutral.700}", "$type": "color" },
    "chart-5": { "$value": "{primitives.color.neutral.800}", "$type": "color" },
    "sidebar-background": { "$value": "{primitives.color.neutral.50}", "$type": "color" },
    "sidebar-foreground": { "$value": "{primitives.color.neutral.950}", "$type": "color" },
    "sidebar-primary": { "$value": "{primitives.color.neutral.900}", "$type": "color" },
    "sidebar-on-primary": { "$value": "{primitives.color.neutral.50}", "$type": "color" },
    "sidebar-accent": { "$value": "{primitives.color.neutral.100}", "$type": "color" },
    "sidebar-on-accent": { "$value": "{primitives.color.neutral.900}", "$type": "color" },
    "sidebar-border": { "$value": "{primitives.color.neutral.200}", "$type": "color" },
    "sidebar-ring": { "$value": "{primitives.color.neutral.400}", "$type": "color" },
    "foreground-white": { "$value": "{primitives.color.white}", "$type": "color" },
    "background-primary-hover": { "$value": "{primitives.color.neutral.800}", "$type": "color" },
    "background-secondary-hover": { "$value": "{primitives.color.neutral.100}", "$type": "color" },
    "background-accent-subtle": { "$value": "{primitives.color.neutral.50}", "$type": "color" },
    "background-muted-subtle": { "$value": "{primitives.color.neutral.50}", "$type": "color" },
    "background-primary-subtle": { "$value": "{primitives.color.neutral.200}", "$type": "color" },
    "background-destructive-hover": { "$value": "{primitives.color.red.500}", "$type": "color" },
    "background-destructive-subtle": { "$value": "{primitives.color.red.200}", "$type": "color" },
    "ring-focus": { "$value": "{primitives.color.neutral.300}", "$type": "color" },
    "ring-error": { "$value": "{primitives.color.red.200}", "$type": "color" },
    "input-background": { "$value": "{primitives.alpha.white.0}", "$type": "color" },
    "input-background-hover": { "$value": "{primitives.color.neutral.100}", "$type": "color" },
    "background-overlay": { "$value": "{primitives.alpha.black.50}", "$type": "color" },
    "foreground-destructive": { "$value": "{primitives.color.red.600}", "$type": "color" },
    "background-success": { "$value": "{primitives.color.green.100}", "$type": "color", "$description": "Status surface — success pill fill (e.g. session 'Complete'). Pairs with foreground-success." },
    "foreground-success": { "$value": "{primitives.color.green.700}", "$type": "color", "$description": "Status text — success pill label and positive inline cues ('connection successful', 'key stored'). Pairs with background-success." },
    "background-info": { "$value": "{primitives.color.blue.100}", "$type": "color", "$description": "Status surface — info pill fill. Pairs with foreground-info." },
    "foreground-info": { "$value": "{primitives.color.blue.700}", "$type": "color", "$description": "Status text — info pill label. Pairs with background-info." },
    "background-warning": { "$value": "{primitives.color.yellow.100}", "$type": "color", "$description": "Status surface — warning pill fill (e.g. session 'In progress'). Pairs with foreground-warning." },
    "foreground-warning": { "$value": "{primitives.color.yellow.700}", "$type": "color", "$description": "Status text — warning pill label. Pairs with background-warning." },
    "background-error": { "$value": "{primitives.color.red.100}", "$type": "color", "$description": "Status surface — error pill fill. Pairs with foreground-error. Distinct from background-destructive (solid danger actions)." },
    "foreground-error": { "$value": "{primitives.color.red.700}", "$type": "color", "$description": "Status text — error pill label. Pairs with background-error. Distinct from foreground-destructive (inline danger text)." },
    "border-success-subtle": { "$value": "{primitives.color.green.100}", "$type": "color", "$description": "Status stroke — success, surface-equivalent (matches background-success). STROKE_COLOR-scoped counterpart so a status colour can paint a border." },
    "border-success-emphasis": { "$value": "{primitives.color.green.700}", "$type": "color", "$description": "Status stroke — success, text-equivalent (matches foreground-success)." },
    "border-info-subtle": { "$value": "{primitives.color.blue.100}", "$type": "color", "$description": "Status stroke — info, surface-equivalent (matches background-info)." },
    "border-info-emphasis": { "$value": "{primitives.color.blue.700}", "$type": "color", "$description": "Status stroke — info, text-equivalent (matches foreground-info)." },
    "border-warning-subtle": { "$value": "{primitives.color.yellow.100}", "$type": "color", "$description": "Status stroke — warning, surface-equivalent (matches background-warning)." },
    "border-warning-emphasis": { "$value": "{primitives.color.yellow.700}", "$type": "color", "$description": "Status stroke — warning, text-equivalent (matches foreground-warning)." },
    "border-error-subtle": { "$value": "{primitives.color.red.100}", "$type": "color", "$description": "Status stroke — error, surface-equivalent (matches background-error)." },
    "border-error-emphasis": { "$value": "{primitives.color.red.700}", "$type": "color", "$description": "Status stroke — error, text-equivalent (matches foreground-error)." },
    "border-destructive": { "$value": "{primitives.color.red.600}", "$type": "color" },
    "border-primary": { "$value": "{primitives.color.neutral.900}", "$type": "color", "$description": "Border/stroke on checked or selected (primary-emphasis) controls: checked checkbox box, selected rich-group card, slider thumb. Same primitives as background-primary — created in the PEA-219 border-role correction (a background token must not paint strokes)." },
    "border-subtle": { "$value": "{primitives.color.neutral.100}", "$type": "color", "$description": "Hairline border one step quieter than border-default — the charts grid-line color. Promoted from Figma's unofficial/border-1 (259 Charts grid-line bindings) in the PEA-219 reorg." }
  }
}
