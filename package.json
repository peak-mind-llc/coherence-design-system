{
  "name": "@coherence/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Coherence Workstation design system — shadcn-aligned tokens, Inter font, typography utilities. Web-consumable today; RN-ready when the recorder integration begins.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./dist/tokens.ts",
    "./tokens.css": "./dist/tokens.css",
    "./fonts.css": "./fonts.css",
    "./base.css": "./base.css",
    "./ui/*": "./src/components/ui/*.tsx",
    "./lib/utils": "./src/lib/utils.ts",
    "./hooks/use-mobile": "./src/hooks/use-mobile.ts"
  },
  "files": [
    "src/",
    "tokens/",
    "dist/",
    "fonts/",
    "fonts.css",
    "base.css"
  ],
  "scripts": {
    "build": "node style-dictionary.config.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "culori": "^4.0.2",
    "style-dictionary": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@shadcn/react": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "peerDependenciesMeta": {
    "@shadcn/react": { "optional": true },
    "class-variance-authority": { "optional": true },
    "clsx": { "optional": true },
    "cmdk": { "optional": true },
    "embla-carousel-react": { "optional": true },
    "input-otp": { "optional": true },
    "lucide-react": { "optional": true },
    "next-themes": { "optional": true },
    "radix-ui": { "optional": true },
    "react": { "optional": true },
    "react-day-picker": { "optional": true },
    "react-dom": { "optional": true },
    "react-resizable-panels": { "optional": true },
    "sonner": { "optional": true },
    "tailwind-merge": { "optional": true },
    "vaul": { "optional": true }
  },
  "license": "Apache-2.0"
}
