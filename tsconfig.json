{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "dist/**/*.ts"],
  // The React kit (src/components, src/lib, src/hooks) needs DOM/jsx and the
  // consumer's node_modules — desktop's `tsc --noEmit` type-checks it via its
  // tsconfig `include`. This package-level typecheck covers tokens only.
  "exclude": ["src/components", "src/lib", "src/hooks"]
}
